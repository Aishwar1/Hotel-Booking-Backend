{
  "name": "quickstay",
  "version": "1.0.0",
  "description": "QuickStay - Full-stack hotel booking platform (React + Express + MongoDB)",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "start": "NODE_ENV=production node server/server.js",
    "build": "cd client && npm install && npm run build",
    "dev:server": "cd server && node server.js",
    "dev:client": "cd client && npm run dev",
    "seed": "cd server && node seed.js"
  },
  "dependencies": {
    "@clerk/express": "^2.1.43",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.6.0",
    "helmet": "^8.3.0",
    "mongoose": "^9.8.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "openai": "^6.48.0",
    "stripe": "^22.3.2",
    "svix": "^1.98.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}